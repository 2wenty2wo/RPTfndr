{
  "name": "meshcore-finder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A hosted PWA with device-local data for narrowing the search area of a MeshCore repeater.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2wenty2wo/RPTfndr.git"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:hosting": "node scripts/verify-hosted-build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@michaelhart/meshcore-decoder": "^0.3.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@noble/ed25519": "^3.0.0",
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.0.0",
    "@types/leaflet": "^1.9.20",
    "@types/web-bluetooth": "^0.0.21",
    "eslint": "^9.39.0",
    "fake-indexeddb": "^6.2.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.0.0"
  }
}
